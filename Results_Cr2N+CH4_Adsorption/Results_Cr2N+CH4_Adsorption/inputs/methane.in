&CONTROL
    calculation = 'relax',
    restart_mode = 'from_scratch',
    prefix = 'Cr2N_CH4',
    nstep = 200,
    pseudo_dir = '../pseudos/',
    outdir = '../tmp/',
    max_seconds=86100
/

&SYSTEM
    ntyp = 4,
    nat = 77,
    ibrav = 0,
    ecutwfc = 60,
    ecutrho = 480,
    occupations = 'smearing', smearing = 'mp', degauss = 0.02,
    vdw_corr = 'dft-d3',
/

&ELECTRONS
    conv_thr = 1.0d-8,
    mixing_beta = 0.2,
    diagonalization = 'david'
/

&IONS
    ion_dynamics = 'bfgs'
/

&CELL
/

ATOMIC_SPECIES
Cr 51.9961 cr_pbe_v1.5.uspp.F.UPF
N  14.0067 N.pbe-n-radius_5.UPF
C  12.011  C.pbe-n-kjpaw_psl.1.0.0.UPF
H  1.008   H.pbe-rrkjus_psl.1.0.0.UPF

K_POINTS automatic
4 4 1 0 0 0

CELL_PARAMETERS angstrom
9.5027394073 0.0 0.0
-4.7513697036 8.2296098952 0.0
0.0 0.0 20.75351356

ATOMIC_POSITIONS angstrom
C    0.000000    0.000000    0.000000
H    0.629300    0.629300    0.629300
H   -0.629300   -0.629300    0.629300
H   -0.629300    0.629300   -0.629300
H    0.629300   -0.629300   -0.629300